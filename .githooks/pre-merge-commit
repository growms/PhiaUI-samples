#!/usr/bin/env bash
# Runs the Playwright smoke suite before finalising a merge commit.
# Fires only on non-fast-forward merges — on a plain `git pull` that
# fast-forwards there is no merge commit, so nothing runs.
#
# Skip with: git merge --no-verify ...
# Uninstall with: git config --unset core.hooksPath

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT/e2e"

if [ ! -d node_modules ]; then
  echo "[pre-merge-commit] e2e/node_modules missing — run 'cd e2e && npm install' once, then retry."
  exit 1
fi

echo "[pre-merge-commit] running Playwright smoke suite (takes ~15s)…"
npx playwright test smoke.spec.ts --reporter=line
